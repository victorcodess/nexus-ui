{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "nexus-ui",
  "homepage": "https://nexus-ui.dev",
  "items": [
    {
      "name": "nexus-ui-theme",
      "type": "registry:theme",
      "title": "Nexus UI theme",
      "description": "Tailwind v4 shadow and scale tokens used by Nexus UI components.",
      "cssVars": {
        "theme": {
          "shadow-sm": "0 2px 4px -2px rgba(0, 0, 0, 0.06), 0 4px 4px -2px rgba(0, 0, 0, 0.06)",
          "shadow-modal": "0 -4px 12px 4px rgba(0, 0, 0, 0.04), 0 4px 12px -4px rgba(0, 0, 0, 0.06)",
          "scale-97": "0.97",
          "scale-99": "0.99"
        }
      }
    },
    {
      "name": "prompt-input",
      "type": "registry:ui",
      "title": "Prompt Input",
      "description": "A composable AI chat input component with auto-resizing textarea and action slots.",
      "dependencies": ["@radix-ui/react-slot"],
      "registryDependencies": ["textarea", "scroll-area"],
      "files": [
        {
          "path": "registry/new-york/prompt-input/prompt-input.tsx",
          "type": "registry:file",
          "target": "~/components/nexus-ui/prompt-input.tsx"
        }
      ]
    },
    {
      "name": "suggestions",
      "type": "registry:ui",
      "title": "Suggestions",
      "description": "Composable prompt suggestion chips for guiding user input.",
      "dependencies": ["@radix-ui/react-slot"],
      "registryDependencies": ["@nexus-ui/nexus-ui-theme", "button"],
      "files": [
        {
          "path": "registry/new-york/suggestions/suggestions.tsx",
          "type": "registry:file",
          "target": "~/components/nexus-ui/suggestions.tsx"
        }
      ]
    },
    {
      "name": "attachments",
      "type": "registry:ui",
      "title": "Attachments",
      "description": "Composable file-attachment UI for inputs and messages with compact, inline, and detailed variants.",
      "dependencies": [
        "@radix-ui/react-slot",
        "class-variance-authority",
        "@hugeicons/react",
        "@hugeicons/core-free-icons"
      ],
      "registryDependencies": ["@nexus-ui/nexus-ui-theme"],
      "files": [
        {
          "path": "registry/new-york/attachments/attachments.tsx",
          "type": "registry:file",
          "target": "~/components/nexus-ui/attachments.tsx"
        }
      ]
    },
    {
      "name": "model-selector",
      "type": "registry:ui",
      "title": "Model Selector",
      "description": "A dropdown for selecting an AI model with radio groups, sub-menus, and custom items.",
      "dependencies": [
        "radix-ui",
        "@hugeicons/react",
        "@hugeicons/core-free-icons"
      ],
      "registryDependencies": ["@nexus-ui/nexus-ui-theme"],
      "files": [
        {
          "path": "registry/new-york/model-selector/model-selector.tsx",
          "type": "registry:file",
          "target": "~/components/nexus-ui/model-selector.tsx"
        }
      ]
    },
    {
      "name": "message",
      "type": "registry:ui",
      "title": "Message",
      "description": "Composable chat message layout with markdown body, actions, and avatar.",
      "dependencies": [
        "streamdown",
        "@streamdown/cjk",
        "@streamdown/code",
        "@streamdown/math",
        "@streamdown/mermaid",
        "radix-ui",
        "@radix-ui/react-slot",
        "@hugeicons/react",
        "@hugeicons/core-free-icons"
      ],
      "registryDependencies": ["button", "avatar"],
      "css": {
        "@source \"../node_modules/streamdown/dist/index.js\"": {},
        "@source \"../node_modules/@streamdown/code/dist/*.js\"": {},
        "@source \"../node_modules/@streamdown/mermaid/dist/*.js\"": {},
        "@source \"../node_modules/@streamdown/math/dist/*.js\"": {},
        "@source \"../node_modules/@streamdown/cjk/dist/*.js\"": {},
        "@layer base": {
          "code": {
            "counter-reset": "line"
          },
          "code .line::before": {
            "counter-increment": "line",
            "content": "counter(line)",
            "display": "inline-block",
            "width": "1rem",
            "margin-right": "1.25rem",
            "text-align": "right",
            "color": "#737373",
            "padding-left": "0",
            "font-size": "14px"
          },
          "code .line": {
            "padding-left": "0px !important"
          },
          ".no-scrollbar": {
            "-ms-overflow-style": "none",
            "scrollbar-width": "none"
          },
          ".no-scrollbar::-webkit-scrollbar": {
            "display": "none"
          }
        }
      },
      "files": [
        {
          "path": "registry/new-york/message/message.tsx",
          "type": "registry:file",
          "target": "~/components/nexus-ui/message.tsx"
        },
        {
          "path": "registry/new-york/message/codeblock.tsx",
          "type": "registry:file",
          "target": "~/components/nexus-ui/codeblock.tsx"
        }
      ]
    },
    {
      "name": "thread",
      "type": "registry:ui",
      "title": "Thread",
      "description": "Chat thread viewport with stick-to-bottom scrolling and a scroll-to-bottom control.",
      "dependencies": [
        "@radix-ui/react-slot",
        "@hugeicons/react",
        "@hugeicons/core-free-icons",
        "use-stick-to-bottom"
      ],
      "registryDependencies": ["@nexus-ui/nexus-ui-theme"],
      "files": [
        {
          "path": "registry/new-york/thread/thread.tsx",
          "type": "registry:file",
          "target": "~/components/nexus-ui/thread.tsx"
        }
      ]
    },
    {
      "name": "citation",
      "type": "registry:ui",
      "title": "Citation",
      "description": "Composable inline citations with hover preview, multi-source carousel, and favicons.",
      "dependencies": [
        "radix-ui",
        "@hugeicons/react",
        "@hugeicons/core-free-icons",
        "tldts"
      ],
      "registryDependencies": [
        "@nexus-ui/nexus-ui-theme",
        "carousel",
        "hover-card"
      ],
      "files": [
        {
          "path": "registry/new-york/citation/citation.tsx",
          "type": "registry:file",
          "target": "~/components/nexus-ui/citation.tsx"
        }
      ]
    },
    {
      "name": "reasoning",
      "type": "registry:ui",
      "title": "Reasoning",
      "description": "Collapsible AI reasoning block with streaming-aware trigger label and markdown content.",
      "dependencies": [
        "@hugeicons/react",
        "@hugeicons/core-free-icons",
        "streamdown"
      ],
      "registryDependencies": ["collapsible"],
      "css": {
        "@import \"tw-shimmer\"": {},
        "@layer utilities": {
          "@keyframes reasoning-expand": {
            "from": {
              "height": "0"
            },
            "to": {
              "height": "var(--radix-collapsible-content-height)"
            }
          },
          "@keyframes reasoning-collapse": {
            "from": {
              "height": "var(--radix-collapsible-content-height)"
            },
            "to": {
              "height": "0"
            }
          },
          ".animate-collapsible-down": {
            "animation": "reasoning-expand 0.2s ease-out"
          },
          ".animate-collapsible-up": {
            "animation": "reasoning-collapse 0.2s ease-out"
          }
        }
      },
      "files": [
        {
          "path": "registry/new-york/reasoning/reasoning.tsx",
          "type": "registry:file",
          "target": "~/components/nexus-ui/reasoning.tsx"
        }
      ]
    }
  ]
}
