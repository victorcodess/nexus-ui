{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "nexus-ui",
  "homepage": "https://nexus-ui.dev",
  "items": [
    {
      "name": "nexus-ui-theme",
      "type": "registry:theme",
      "title": "Nexus UI theme",
      "description": "Tailwind v4 theme tokens (gray palette, shadows, scale) used by Nexus UI components.",
      "cssVars": {
        "theme": {
          "color-gray-50": "#fafafa",
          "color-gray-100": "#f5f5f5",
          "color-gray-200": "#e5e5e5",
          "color-gray-300": "#d4d4d4",
          "color-gray-400": "#a3a3a3",
          "color-gray-500": "#737373",
          "color-gray-600": "#525252",
          "color-gray-700": "#404040",
          "color-gray-800": "#262626",
          "color-gray-900": "#171717",
          "color-gray-950": "#0a0a0a",
          "shadow-sm": "0 2px 4px -2px rgba(0, 0, 0, 0.06), 0 4px 4px -2px rgba(0, 0, 0, 0.06)",
          "shadow-modal": "0 -4px 12px 4px rgba(0, 0, 0, 0.04), 0 4px 12px -4px rgba(0, 0, 0, 0.06)",
          "scale-96": "0.96",
          "scale-97": "0.97",
          "scale-98": "0.98",
          "scale-99": "0.99"
        }
      }
    },
    {
      "name": "prompt-input",
      "type": "registry:ui",
      "title": "Prompt Input",
      "description": "A composable AI chat input component with auto-resizing textarea and action slots.",
      "dependencies": ["@radix-ui/react-slot"],
      "registryDependencies": [
        "nexus-ui-theme",
        "textarea",
        "scroll-area"
      ],
      "files": [
        {
          "path": "registry/new-york/prompt-input/prompt-input.tsx",
          "type": "registry:file",
          "target": "~/components/nexus-ui/prompt-input.tsx"
        }
      ]
    },
    {
      "name": "suggestions",
      "type": "registry:ui",
      "title": "Suggestions",
      "description": "Composable prompt suggestion chips for guiding user input.",
      "dependencies": ["@radix-ui/react-slot"],
      "registryDependencies": ["nexus-ui-theme", "button"],
      "files": [
        {
          "path": "registry/new-york/suggestions/suggestions.tsx",
          "type": "registry:file",
          "target": "~/components/nexus-ui/suggestions.tsx"
        }
      ]
    },
    {
      "name": "attachments",
      "type": "registry:ui",
      "title": "Attachments",
      "description": "Composable file-attachment UI for inputs and messages with compact, inline, and detailed variants.",
      "dependencies": [
        "@radix-ui/react-slot",
        "class-variance-authority",
        "@hugeicons/react",
        "@hugeicons/core-free-icons"
      ],
      "registryDependencies": ["nexus-ui-theme"],
      "files": [
        {
          "path": "registry/new-york/attachments/attachments.tsx",
          "type": "registry:file",
          "target": "~/components/nexus-ui/attachments.tsx"
        }
      ]
    },
    {
      "name": "model-selector",
      "type": "registry:ui",
      "title": "Model Selector",
      "description": "A dropdown for selecting an AI model with radio groups, sub-menus, and custom items.",
      "dependencies": [
        "radix-ui",
        "@hugeicons/react",
        "@hugeicons/core-free-icons"
      ],
      "registryDependencies": ["nexus-ui-theme"],
      "files": [
        {
          "path": "registry/new-york/model-selector/model-selector.tsx",
          "type": "registry:file",
          "target": "~/components/nexus-ui/model-selector.tsx"
        }
      ]
    },
    {
      "name": "message",
      "type": "registry:ui",
      "title": "Message",
      "description": "Composable chat message layout with markdown body, actions, and avatar.",
      "dependencies": [
        "streamdown",
        "@streamdown/cjk",
        "@streamdown/code",
        "@streamdown/math",
        "@streamdown/mermaid",
        "radix-ui",
        "@radix-ui/react-slot"
      ],
      "registryDependencies": ["nexus-ui-theme", "button", "avatar"],
      "files": [
        {
          "path": "registry/new-york/message/message.tsx",
          "type": "registry:file",
          "target": "~/components/nexus-ui/message.tsx"
        }
      ]
    }
  ]
}
